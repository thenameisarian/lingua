{ "id":"a1-07","level":"A1","module":"Out and about","title":"Numbers & money","theme":"Prices and paying","canDo":"I can ask prices and pay for things.",
  "chunks":[
    {"id":"a107_cost","text":"How much does it cost?","use":"Ask a price.","example":"How much does it cost?","freqTier":1},
    {"id":"a107_five","text":"It's five dollars.","use":"Give a price.","example":"It's five dollars.","freqTier":1},
    {"id":"a107_change","text":"Do you have change?","use":"Ask for smaller money.","example":"Do you have change for ten?","freqTier":2},
    {"id":"a107_toomuch","text":"That's too much.","use":"Say a price is high.","example":"Forty? That's too much.","freqTier":2},
