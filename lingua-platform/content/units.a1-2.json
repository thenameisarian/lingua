    "questions":[{"q":"What day is it?","choices":["Monday","Friday","Sunday"],"a":0},{"q":"When does the shop open?","choices":["At nine","At seven"],"a":0}],
    "vocabInContext":{"q":"'See you on Friday' arranges…","choices":["a day to meet","a price","a place"],"a":0}},
  "listening":{"script":[{"s":"A","t":"What time do you open?"},{"s":"B","t":"We open at nine."}],
    "gist":{"q":"When do they open?","choices":["Nine","Ten"],"a":0},
    "dictogloss":{"sentence":"What day is it today?"},"gap":{"q":"We open at ___ .","a":"nine","accept":["nine"]}},
  "speaking":{"shadow":["a108_day","a108_monday","a108_open","a108_nine","a108_friday"],
    "minimalPair":{"a":"day","b":"die","note":"/eɪ/ 'day' vs /aɪ/ 'die'."},
    "fluency432":{"prompt":"Ask about a shop's day and opening time, and arrange to visit."},
    "retell":{"prompt":"Retell the conversation about the shop's hours.","useChunks":["a108_day","a108_open","a108_nine","a108_friday"],"minWords":12},
    "task":{"prompt":"Ask what time a place opens and arrange a day to go.","useChunks":["a108_open","a108_nine","a108_friday"],"need":2}},
  "writing":{"model":"What day is it today? It's Monday. What time do you open? We open at nine. See you on Friday.",
    "sentenceCombining":[{"parts":["We open at nine.","See you then."],"answer":"We open at nine, so see you then."},{"parts":["It's Monday.","The shop is open."],"answer":"It's Monday, and the shop is open."}],
    "task":{"prompt":"Write 2-3 sentences arranging to meet on a day and time.","genre":"message","mustInclude":["a108_friday","a108_nine"],"minWords":8}},
  "review":{"srItems":["a108_day","a108_monday","a108_open","a108_nine","a108_friday"]},
  "quiz":[{"type":"situation","q":"Ask what day it is.","options":["What day is it today?","We open at nine.","See you on Friday."],"a":0},
    {"type":"situation","q":"Ask a shop's opening time.","options":["What time do you open?","It's Monday.","Here you are."],"a":0},
    {"type":"cloze","q":"See you ___ Friday.","a":"on","accept":["on"]}]
},
