  "grammar":{"focus":"Numbers and prices","pattern":"It's + number + dollars / How much...?","examples":["It's ten dollars.","How much is the ticket?"],"enhance":"prices (it's, how much)"},
  "reading":{"passage":"At the market I ask, how much does it cost? The seller says, it's five dollars. I only have a twenty, so I ask, do you have change? Forty for two? That's too much. In the end I pay and say, here you are.",
    "questions":[{"q":"What is the price of one?","choices":["Five dollars","Twenty dollars","Forty dollars"],"a":0},{"q":"What does the buyer think about forty for two?","choices":["A good deal","Too much"],"a":1}],
    "vocabInContext":{"q":"'Do you have change?' asks for…","choices":["smaller money","a discount","a bag"],"a":0}},
  "listening":{"script":[{"s":"A","t":"How much does it cost?"},{"s":"B","t":"It's five dollars."}],
    "gist":{"q":"What is the price?","choices":["Five dollars","Ten dollars"],"a":0},
    "dictogloss":{"sentence":"How much does it cost?"},"gap":{"q":"It's five ___ .","a":"dollars","accept":["dollars"]}},
  "speaking":{"shadow":["a107_cost","a107_five","a107_change","a107_toomuch","a107_hereyou"],
    "minimalPair":{"a":"cost","b":"coast","note":"short 'cost' vs long 'coast'."},
    "fluency432":{"prompt":"Buy something at a market and pay for it."},
    "retell":{"prompt":"Retell the market conversation.","useChunks":["a107_cost","a107_five","a107_change","a107_hereyou"],"minWords":12},
    "task":{"prompt":"Ask the price of something and pay for it.","useChunks":["a107_cost","a107_change","a107_hereyou"],"need":2}},
  "writing":{"model":"How much does it cost? It's five dollars. Do you have change? Here you are.",
    "sentenceCombining":[{"parts":["It's five dollars.","Here you are."],"answer":"It's five dollars, so here you are."},{"parts":["It's forty dollars.","That's too much."],"answer":"It's forty dollars, which is too much."}],
    "task":{"prompt":"Write a short buying conversation (2-3 sentences).","genre":"dialogue","mustInclude":["a107_cost","a107_change"],"minWords":8}},
  "review":{"srItems":["a107_cost","a107_five","a107_change","a107_toomuch","a107_hereyou"]},
  "quiz":[{"type":"situation","q":"Ask how much something costs.","options":["How much does it cost?","Here you are.","That's too much."],"a":0},
    {"type":"situation","q":"Say a price is too high.","options":["That's too much.","Here you are.","Do you have change?"],"a":0},
    {"type":"cloze","q":"How much does it ___ ?","a":"cost","accept":["cost"]}]
},
{ "id":"a1-08","level":"A1","module":"Daily life","title":"Days & time","theme":"Days, times, opening hours","canDo":"I can ask and say the day and time.",
  "chunks":[
    {"id":"a108_day","text":"What day is it today?","use":"Ask the day.","example":"What day is it today?","freqTier":1},
